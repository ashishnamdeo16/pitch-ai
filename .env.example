# ═══════════════════════════════════════════════════════════════
# PitchPilot AI — Environment Variables
# Copy to web/.env.local and realtime-server/.env
# ═══════════════════════════════════════════════════════════════

# ─── Database (Supabase PostgreSQL) ───
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ─── Supabase Auth ───
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── OpenAI (optional) ───
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"

# ─── Google Gemini (optional — free tier via AI Studio, no card required) ───
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY="AIza..."
GEMINI_MODEL="gemini-2.5-flash"

# ─── Deepgram (optional — falls back to Web Speech API) ───
DEEPGRAM_API_KEY="your-deepgram-key"
NEXT_PUBLIC_USE_DEEPGRAM="false"

# ─── Redis / Upstash ───
UPSTASH_REDIS_REST_URL="https://[REGION]-[ID].upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
REDIS_URL="redis://default:[PASSWORD]@[HOST]:6379"

# ─── Realtime WebSocket Server (Railway) ───
NEXT_PUBLIC_WS_URL="http://localhost:3001"
WS_PORT=3001
WS_CORS_ORIGIN="http://localhost:3000"
WS_HEARTBEAT_MS=25000
WS_SESSION_TTL_SEC=3600

# ─── App URLs ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Rate Limiting ───
RATE_LIMIT_REQUESTS_PER_MIN=60

# ─── Session Secrets ───
SESSION_SECRET="generate-a-32-char-random-string"
WS_TOKEN_SECRET="generate-a-32-char-random-string-for-ws-jwt"
